{
  "name": "c-suite",
  "version": "0.1.0",
  "description": "A repo-grounded, self-grading calibration instrument: record decisions as falsifiable forecasts, resolve them against git reality with a deterministic verifier, and track your calibration over a tamper-evident ledger.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Jake Castillo",
  "bin": { "csuite": "bin/csuite.mjs" },
  "files": ["dist", "bin", "README.md", "LICENSE", "NOTICE"],
  "engines": { "node": ">=20" },
  "keywords": [
    "calibration",
    "forecasting",
    "brier-score",
    "decision-ledger",
    "git",
    "cli",
    "founder-tools"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src test",
    "check": "pnpm typecheck && pnpm build && pnpm test && pnpm lint",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": { "zod": "^3.23.8" },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "@types/node": "^22.9.0"
  }
}
